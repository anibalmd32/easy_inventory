generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id         Int      @id @default(autoincrement())
    name       String   @unique
    email      String   @unique
    password   String
    createdAt  DateTime @default(now()) @map("created_at")
    updatedAt  DateTime @default(now()) @map("updated_at")
    isAdmin    Boolean  @default(false)
    isEmployee Boolean  @default(false)

    @@map("users")
}

model Category {
    id        Int       @id @default(autoincrement())
    name      String    @unique
    color     String
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @default(now()) @map("updated_at")
    products  Product[]

    @@map("categories")
}

model Product {
    id          Int           @id @default(autoincrement())
    name        String        @unique
    price       Decimal       @db.Decimal(9, 2)
    quantity    Int
    categoryId  Int?          @map("category_id")
    createdAt   DateTime      @default(now()) @map("created_at")
    updatedAt   DateTime      @default(now()) @map("updated_at")
    isActive    Boolean       @default(true) @map("is_active")
    category    Category?     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
    sales       Sale[]
    shopingList ShopingList[]

    @@map("products")
}

model ShopingList {
    id          Int      @id @default(autoincrement())
    productId   Int      @map("product_id")
    isPurchased Boolean  @map("is_purchased")
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @default(now()) @map("updated_at")
    product     Product  @relation(fields: [productId], references: [id])

    @@map("shopping_list")
}

model Sale {
    id               Int              @id @default(autoincrement())
    productId        Int              @map("product_id")
    productQuantity  Int              @map("product_quantity")
    createdAt        DateTime         @default(now()) @map("created_at")
    updatedAt        DateTime         @default(now()) @map("updated_at")
    product          Product          @relation(fields: [productId], references: [id])
    salesToCustomers SaleToCustomer[]

    @@map("sales")
}

model Customer {
    id               Int              @id @default(autoincrement())
    name             String
    dni              String           @unique
    din_prefix       String           @default("V")
    phone            String
    createdAt        DateTime         @default(now()) @map("created_at")
    updatedAt        DateTime         @default(now()) @map("updated_at")
    invoices         Invoice[]
    salesToCustomers SaleToCustomer[]

    @@map("customers")
}

model SaleToCustomer {
    id         Int      @id @default(autoincrement())
    customerId Int      @map("customer_id")
    saleId     Int      @map("sale_id")
    createdAt  DateTime @default(now()) @map("created_at")
    updatedAt  DateTime @default(now()) @map("updated_at")
    customer   Customer @relation(fields: [customerId], references: [id])
    sale       Sale     @relation(fields: [saleId], references: [id])

    @@map("sales_to_customers")
}

model Invoice {
    id          Int       @id @default(autoincrement())
    items       Json
    total       Decimal   @db.Decimal(9, 2)
    status      Int
    generatedAt DateTime  @default(now()) @map("generated_at")
    paidAt      DateTime? @map("paid_at")
    canceledAt  DateTime? @map("canceled_at")
    customerId  Int       @map("customer_id")
    createdAt   DateTime  @default(now()) @map("created_at")
    updatedAt   DateTime  @default(now()) @map("updated_at")
    customer    Customer  @relation(fields: [customerId], references: [id])

    @@map("invoices")
}

model InvoiceTemplate {
    id        Int      @id @default(autoincrement())
    name      String   @unique
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @default(now()) @map("updated_at")
    setting   Setting?

    @@map("invoice_templates")
}

model Setting {
    id                Int             @id @default(autoincrement())
    businessName      String          @default("Easy Inventory") @map("business_name")
    logoUrl           String          @default("/favicon.svg") @map("logo_url")
    minimumStock      Int             @default(5) @map("minimum_stock")
    invoiceTemplateId Int             @unique
    email             String          @unique
    password          String
    createdAt         DateTime        @default(now()) @map("created_at")
    updatedAt         DateTime        @default(now()) @map("updated_at")
    invoiceTemplate   InvoiceTemplate @relation(fields: [invoiceTemplateId], references: [id])

    @@map("settings")
}

model Notification {
    id          Int      @id @default(autoincrement())
    action      Int
    description String
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @default(now()) @map("updated_at")
    emitedAt    DateTime @default(now()) @map("emited_at")

    @@map("notifications")
}
